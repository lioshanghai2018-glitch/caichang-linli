{
  "bsonType": "object",
  "required": ["_id"],
  "properties": {
    "_id": { "bsonType": "string" },
    "userId": { "bsonType": "string", "title": "发帖人" },
    "communityId": { "bsonType": "string", "defaultValue": "" },
    "type": { "bsonType": "string", "defaultValue": "share", "description": "share / help / trade" },
    "title": { "bsonType": "string" },
    "content": { "bsonType": "string" },
    "images": { "bsonType": "array", "defaultValue": [] },
    "likeCount": { "bsonType": "int", "defaultValue": 0 },
    "commentCount": { "bsonType": "int", "defaultValue": 0 },
    "likedUserIds": { "bsonType": "array", "defaultValue": [] },
    "status": { "bsonType": "string", "defaultValue": "active", "description": "active / closed / deleted" },
    "downReason": { "bsonType": "string", "defaultValue": "" },
    "downAt": { "bsonType": "datetime" },
    "downBy": { "bsonType": "string", "defaultValue": "" },
    "createdAt": { "bsonType": "datetime", "forceDefaultValue": { "$env": "now" } },
    "updatedAt": { "bsonType": "datetime", "forceDefaultValue": { "$env": "now" } }
  }
}
