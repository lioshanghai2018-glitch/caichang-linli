{
  "bsonType": "object",
  "required": ["_id"],
  "properties": {
    "_id": { "bsonType": "string" },
    "merchantId": { "bsonType": "string" },
    "name": { "bsonType": "string", "title": "小区名" },
    "address": { "bsonType": "string" },
    "longitude": { "bsonType": "double", "defaultValue": 0 },
    "latitude": { "bsonType": "double", "defaultValue": 0 },
    "houseCount": { "bsonType": "int", "defaultValue": 0 },
    "userCount": { "bsonType": "int", "defaultValue": 0 },
    "status": { "bsonType": "string", "defaultValue": "active" },
    "createdAt": { "bsonType": "datetime", "forceDefaultValue": { "$env": "now" } },
    "updatedAt": { "bsonType": "datetime", "forceDefaultValue": { "$env": "now" } }
  }
}
