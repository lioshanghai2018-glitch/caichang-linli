{
  "bsonType": "object",
  "required": ["_id"],
  "properties": {
    "_id": { "bsonType": "string" },
    "merchantId": { "bsonType": "string" },
    "userId": { "bsonType": "string" },
    "lastMessage": { "bsonType": "string", "defaultValue": "" },
    "lastMessageAt": { "bsonType": "datetime" },
    "unreadCount": { "bsonType": "int", "defaultValue": 0 },
    "status": { "bsonType": "string", "defaultValue": "active" },
    "createdAt": { "bsonType": "datetime", "forceDefaultValue": { "$env": "now" } },
    "updatedAt": { "bsonType": "datetime", "forceDefaultValue": { "$env": "now" } }
  }
}
